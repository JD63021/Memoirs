  CUDA_STANDARD 17
  CUDA_STANDARD_REQUIRED ON
  CXX_STANDARD 17
  CXX_STANDARD_REQUIRED ON
)

target_link_libraries(memoirs_test_structured_gmg_cuda PRIVATE
  CUDA::cudart
  CUDA::cublas
  Threads::Threads
  dl
)


