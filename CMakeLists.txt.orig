# Optional CUDA audit source for the Q1/Q1 HYPRE-IJ Picard assembler.
# The app still solves through HYPRE; this source only assembles values/RHS on CUDA
# for host-vs-device comparison when MEMOIRS_Q1Q1_CUDA_AUDIT_ASSEMBLY=1.
if(TARGET memoirs_test_structured_q1q1_nse_mms_hypre_ij)
  target_sources(memoirs_test_structured_q1q1_nse_mms_hypre_ij PRIVATE
    apps/q1q1_nse_cuda_audit.cu
  )
  set_source_files_properties(apps/q1q1_nse_cuda_audit.cu PROPERTIES LANGUAGE CUDA)
  set_target_properties(memoirs_test_structured_q1q1_nse_mms_hypre_ij PROPERTIES
    CUDA_ARCHITECTURES 86
    CUDA_STANDARD 17
    CUDA_STANDARD_REQUIRED ON
    CXX_STANDARD 17
    CXX_STANDARD_REQUIRED ON
    CUDA_SEPARABLE_COMPILATION OFF
  )
endif()


# Optional CUDA audit source for the Q2/Q1 HYPRE-IJ refactor scaffold.
# This only verifies CUDA can fill fixed-pattern values/RHS before HYPRE IJ use.
if(TARGET memoirs_test_structured_q2q1_nse_mms_hypre_ij)
  target_sources(memoirs_test_structured_q2q1_nse_mms_hypre_ij PRIVATE
    apps/q2q1_nse_cuda_audit.cu
  )
  set_source_files_properties(apps/q2q1_nse_cuda_audit.cu PROPERTIES LANGUAGE CUDA)
