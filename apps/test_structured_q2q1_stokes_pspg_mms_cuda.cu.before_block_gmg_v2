        std::cout << "nu                        = " << cli.nu << "\n";
        std::cout << "tauScale                  = " << cli.tauScale << "\n";
        std::cout << "tauMode                   = " << cli.tauMode << "\n";
        std::cout << "tauC                      = " << cli.tauC << "\n";
        std::cout << "tau                       = " << std::setprecision(8) << double(tau) << "\n";
        std::cout << "tol                       = " << cli.tol << "\n";
        std::cout << "maxit                     = " << cli.maxit << "\n";

        memoirs::gpu::SolverReport rep;
        double totalSeconds=0;
        for (int r=0; r<cli.repeats; ++r) {
            d_x.zero();
            const auto t0=std::chrono::high_resolution_clock::now();
            rep = memoirs::gpu::gmres_right_prec<Real>(A,M,d_b.data(),d_x.data(),Real(cli.tol),cli.maxit,cli.gmresRestart,cli.printEvery);
            const auto t1=std::chrono::high_resolution_clock::now();
            totalSeconds += std::chrono::duration<double>(t1-t0).count();
        }
        const double checked = memoirs::gpu::checked_rel_residual<Real>(A,d_b.data(),d_x.data());
        std::vector<Real> h_x(g.ndof);
        MEMOIRS_CUDA_CHECK(cudaMemcpy(h_x.data(), d_x.data(), sizeof(Real)*std::size_t(g.ndof), cudaMemcpyDeviceToHost));
        const auto err = memoirs::gpu::compute_errors_host(g,h_x);

        std::cout << "--------------- q2q1 stokes pspg solve report ---------------\n";
        std::cout << "iterations                = " << rep.iterations << "\n";
        std::cout << "converged                 = " << rep.converged << "\n";
        std::cout << "breakdown                 = " << rep.breakdown << "\n";
        std::cout << "breakdownCode             = " << rep.breakdownCode << "\n";
        std::cout << std::setprecision(17);
        std::cout << "breakdownValue            = " << rep.breakdownValue << "\n";
        std::cout << "initialResidual           = " << rep.initialResidual << "\n";
        std::cout << "finalResidual             = " << rep.finalResidual << "\n";
        std::cout << "finalRelativeResidual     = " << rep.finalRelativeResidual << "\n";
        std::cout << "checkedRelativeResidual   = " << checked << "\n";
        std::cout << "velocityL2Quadrature      = " << err.velocityL2 << "\n";
        std::cout << "pressureL2Quadrature      = " << err.pressureL2 << "\n";
        std::cout << "pressureMeanShift         = " << err.pressureMeanShift << "\n";
        std::cout << "pressureL2MeanShiftedQuadrature = " << err.pressureL2MeanShifted << "\n";
        std::cout << "--------------------------------------------------------------\n";
        std::cout << "solveSeconds              = " << totalSeconds / double(cli.repeats) << "\n";
        return (rep.converged && checked <= cli.tol*10.0) ? 0 : 2;
    } catch (const std::exception& e) {
        std::cerr << "FATAL: " << e.what() << "\n";
        return 1;
    }
}
